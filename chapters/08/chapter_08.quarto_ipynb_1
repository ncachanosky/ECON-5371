        "\n",
        "# ── Log real GDP (GDPC1) ───────────────────────────────────────────────────────\n",
        "gdp_raw = web.DataReader(\"GDPC1\", \"fred\", start, end)\n",
        "gdp_raw.columns = [\"Real GDP\"]\n",
        "gdp_raw[\"Log GDP\"] = np.log(gdp_raw[\"Real GDP\"])\n",
        "\n",
        "# ── Log real personal consumption expenditures (PCECC96) ──────────────────────\n",
        "pce_raw = web.DataReader(\"PCECC96\", \"fred\", start, end)\n",
        "pce_raw.columns = [\"Real Consumption\"]\n",
        "pce_raw[\"Log Consumption\"] = np.log(pce_raw[\"Real Consumption\"])\n",
        "\n",
        "# ── Merge on quarterly frequency ──────────────────────────────────────────────\n",
        "levels = (gdp_raw[[\"Log GDP\"]]\n",
        "          .join(pce_raw[[\"Log Consumption\"]], how=\"inner\")\n",
        "          .dropna())\n",
