    "#| label: stationarity-tests\n",
    "#| code-fold: true\n",
    "#| code-summary: Show code — ADF and KPSS tests\n",
    "\n",
    "def run_tests(series, name, adf_reg=\"ct\", kpss_reg=\"ct\"):\n",
    "    clean = series.dropna()\n",
    "    adf   = adfuller(clean, regression=adf_reg, autolag=\"AIC\")\n",
    "    kps   = kpss(clean, regression=kpss_reg, nlags=\"auto\")\n",
    "\n",
    "    adf_conc  = (\"Reject H\\u2080 \\u2192 Stationary\"\n",
    "                 if adf[1] < 0.05 else\n",
    "                 \"Fail to reject H\\u2080 \\u2192 Unit root\")\n",
    "    kpss_conc = (\"Reject H\\u2080 \\u2192 Unit root\"\n",
    "                 if kps[1] < 0.05 else\n",
    "                 \"Fail to reject H\\u2080 \\u2192 Stationary\")\n",
    "\n",
    "    print(f\"\\n{'═'*55}\")\n",
    "    print(f\"  Series: {name}\")\n",
    "    print(f\"{'═'*55}\")\n",
    "    print(f\"\\n  ADF Test  (H\\u2080: unit root | spec: '{adf_reg}')\")\n",
    "    print(f\"  {'─'*50}\")\n",
    "    print(f\"  Test statistic   : {adf[0]:>9.4f}\")\n",
    "    print(f\"  p-value          : {adf[1]:>9.4f}\")\n",
    "    print(f\"  Lags (AIC)       : {adf[2]:>9d}\")\n",
    "    for lv, cv in adf[4].items():\n",
    "        print(f\"  Critical val {lv:>4s}: {cv:>9.4f}\")\n",
    "    print(f\"  Conclusion       : {adf_conc}\")\n",
    "    print(f\"\\n  KPSS Test (H\\u2080: stationary | spec: '{kpss_reg}')\")\n",
    "    print(f\"  {'─'*50}\")\n",
    "    print(f\"  Test statistic   : {kps[0]:>9.4f}\")\n",
    "    print(f\"  p-value          : {kps[1]:>9.4f}\")\n",
    "    print(f\"  Bandwidth        : {kps[2]:>9d}\")\n",
    "    for lv, cv in kps[3].items():\n",
    "        print(f\"  Critical val {lv:>4s}: {cv:>9.4f}\")\n",
