        "        \"Min\"        : round(clean.min(),  3),\n",
        "        \"Max\"        : round(clean.max(),  3),\n",
        "        \"ADF Stat\"   : f\"{result[0]:.3f}{stars}\",\n",
        "        \"p-value\"    : round(result[1], 3),\n",
        "        \"Lags (AIC)\" : result[2],\n",
        "        \"Spec.\"      : regression,\n",
