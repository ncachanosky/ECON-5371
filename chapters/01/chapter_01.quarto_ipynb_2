      "source": [
        "#| label: adf-tests\n",
        "#| code-fold: true\n",
        "#| code-summary: Show code — ADF tests\n",
        "\n",
        "def run_adf(series, name, regression=\"ct\"):\n",
        "    \"\"\"Run ADF test and print formatted results.\"\"\"\n",
        "    clean  = series.dropna()\n",
        "    result = adfuller(clean, regression=regression, autolag=\"AIC\")\n",
        "\n",
        "    adf_stat  = result[0]\n",
        "    p_value   = result[1]\n",
        "    n_lags    = result[2]\n",
        "    crit_vals = result[4]\n",
        "    conclusion = (\"Reject H\\u2080 \\u2192 Stationary\" if p_value < 0.05\n",
        "                  else \"Fail to reject H\\u2080 \\u2192 Unit root\")\n",
        "\n",
        "    print(f\"\\n{'─'*52}\")\n",
        "    print(f\"  ADF Test: {name}\")\n",
        "    print(f\"  Specification: '{regression}'\")\n",
        "    print(f\"{'─'*52}\")\n",
        "    print(f\"  Test statistic   : {adf_stat:>9.4f}\")\n",
        "    print(f\"  p-value          : {p_value:>9.4f}\")\n",
        "    print(f\"  Lags (AIC)       : {n_lags:>9d}\")\n",
        "    for level, cv in crit_vals.items():\n",
        "        print(f\"  Critical value {level:>4s}: {cv:>9.4f}\")\n",
        "    print(f\"  Conclusion       : {conclusion}\")\n",
        "    print(f\"{'─'*52}\")\n",
        "\n",
        "run_adf(gdp[\"Log Real GDP\"],      \"Log Real GDP (Level)\",   regression=\"ct\")\n",
        "run_adf(gdp[\"GDP Growth (QoQ)\"],  \"GDP QoQ Growth Rate\",    regression=\"c\")\n",
        "run_adf(cpi[\"Log CPI\"],           \"Log CPI (Level)\",        regression=\"ct\")\n",
        "run_adf(cpi[\"Inflation (YoY)\"],   \"Year-on-Year Inflation\", regression=\"c\")"
      ],
      "id": "adf-tests",
      "execution_count": null,
      "outputs": []
    },
