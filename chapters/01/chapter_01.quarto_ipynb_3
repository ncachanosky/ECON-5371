        "    adf_p    = adf_res[1]\n",
        "    adf_lags = adf_res[2]\n",
        "    adf_cv   = adf_res[4]\n",
        "    adf_conc = (\"Reject H\\u2080 \\u2192 Stationary\"\n",
        "                if adf_p < 0.05 else \"Fail to reject H\\u2080 \\u2192 Unit root\")\n",
        "\n",
        "    # ── KPSS ──────────────────────────────────────────────────────────────────\n",
        "    kpss_res  = kpss(clean, regression=kpss_reg, nlags=\"auto\")\n",
        "    kpss_stat = kpss_res[0]\n",
        "    kpss_p    = kpss_res[1]\n",
        "    kpss_lags = kpss_res[2]\n",
        "    kpss_cv   = kpss_res[3]\n",
        "    kpss_conc = (\"Reject H\\u2080 \\u2192 Unit root\"\n",
        "                 if kpss_p < 0.05 else \"Fail to reject H\\u2080 \\u2192 Stationary\")\n",
