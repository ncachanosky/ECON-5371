        "    H -->|d = 2| K([ARIMA p,2,q\\nRare: verify with\\ntesting on Δy_t\\n→ ARIMAX with regressors])\n",
        "\n",
        "    style A fill:#B87333,color:#FAFAF8,stroke:#B87333\n",
        "    style E fill:#D4745E,color:#FAFAF8,stroke:#D4745E\n",
        "    style F fill:#87A96B,color:#FAFAF8,stroke:#87A96B\n",
        "    style G fill:#8E7AB5,color:#FAFAF8,stroke:#8E7AB5\n",
        "    style I fill:#5B9BD5,color:#FAFAF8,stroke:#5B9BD5\n",
