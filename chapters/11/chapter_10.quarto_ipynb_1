        "#| label: data-nowcast\n",
        "#| include: false\n",
        "\n",
        "# ── Download mixed-frequency data ──────────────────────────────────────────────\n",
        "gdp_raw  = web.DataReader(\"GDPC1\",  \"fred\", \"1959-10-01\", \"2019-12-01\")\n",
        "ip_raw   = web.DataReader(\"INDPRO\", \"fred\", \"1959-12-01\", \"2019-12-01\")\n",
        "ur_raw   = web.DataReader(\"UNRATE\", \"fred\", \"1959-12-01\", \"2019-12-01\")\n",
        "\n",
        "# Annualised log growth: GDP quarterly (×400), IP monthly (×1200)\n",
        "gdp_raw[\"gdp_g\"]  = np.log(gdp_raw[\"GDPC1\"]).diff()  * 400\n",
        "ip_raw[\"ip_g\"]    = np.log(ip_raw[\"INDPRO\"]).diff()   * 1200\n",
        "ur_raw[\"ur_d\"]    = ur_raw[\"UNRATE\"].diff() * 100\n",
        "\n",
        "# Restrict to 1960-01 through 2019-12\n",
        "gdp = gdp_raw.loc[\"1960-01-01\":\"2019-12-01\", [\"gdp_g\"]].dropna()\n",
        "ip  = ip_raw.loc[\"1960-01-01\":\"2019-12-01\",  [\"ip_g\"]].dropna()\n",
        "ur  = ur_raw.loc[\"1960-01-01\":\"2019-12-01\",  [\"ur_d\"]].dropna()\n",
        "\n",
        "# Build a monthly date index covering the full sample\n",
        "monthly_idx = pd.date_range(\"1960-01-01\", \"2019-12-01\", freq=\"MS\")\n",
        "\n",
        "# Expand quarterly GDP to monthly: NaN in months 1 and 2 of each quarter,\n",
        "# GDP value in month 3 (the release month in our stylised timing).\n",
        "# GDPC1 is indexed at the first day of the quarter; we assign it to\n",
        "# the third month of that quarter.\n",
        "gdp_monthly = pd.Series(np.nan, index=monthly_idx, name=\"gdp_g\")\n",
        "for date, val in gdp[\"gdp_g\"].items():\n",
        "    release_month = date + pd.DateOffset(months=2)\n",
        "    if release_month in gdp_monthly.index:\n",
        "        gdp_monthly[release_month] = val\n",
        "\n",
        "# Align monthly indicators to the same index\n",
        "ip_m  = ip[\"ip_g\"].reindex(monthly_idx)\n",
        "ur_m  = ur[\"ur_d\"].reindex(monthly_idx)\n",
        "\n",
        "# Stack into observation matrix: rows = time, cols = [IP, UR, GDP]\n",
        "# GDP column has NaN in months 1-2 of each quarter.\n",
        "obs_data = pd.DataFrame({\n",
        "    \"ip\":  ip_m,\n",
        "    \"ur\":  ur_m,\n",
        "    \"gdp\": gdp_monthly\n",
        "}, index=monthly_idx).dropna(subset=[\"ip\", \"ur\"])\n",
        "\n",
        "# Demean each observable (state tracks deviations from mean growth)\n",
        "ip_mean  = obs_data[\"ip\"].mean()\n",
        "ur_mean  = obs_data[\"ur\"].mean()\n",
        "gdp_mean = obs_data[\"gdp\"].dropna().mean()\n",
        "\n",
        "obs_data[\"ip\"]  -= ip_mean\n",
        "obs_data[\"ur\"]  -= ur_mean\n",
        "obs_data[\"gdp\"] -= gdp_mean   # NaNs preserved after subtraction\n",
        "\n",
        "T_nw     = len(obs_data)\n",
        "nw_dates = obs_data.index"
      ],
